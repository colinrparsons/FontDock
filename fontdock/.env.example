# FontDock Server Configuration
# Copy this file to .env and update the values

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database
DATABASE_URL=sqlite:///./fontdock.db
# For PostgreSQL: postgresql://user:password@localhost/fontdock

# Security
SECRET_KEY=your-secret-key-here-change-this-to-something-random

# Storage
STORAGE_PATH=/opt/fontdock/storage/fonts

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# CORS (if needed for external web UI)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
