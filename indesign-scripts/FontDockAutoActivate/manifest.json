{
  "id": "FontDockAutoActivate",
  "name": "FontDock Auto-Activate",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "ID",
    "minVersion": "21.3.0"
  },
  "manifestVersion": 5,
  "entrypoints": [
    {
      "type": "command",
      "id": "checkFonts",
      "label": {
        "default": "Check Missing Fonts"
      }
    },
    {
      "type": "panel",
      "id": "showPanel",
      "label": {
        "default": "FontDock Status"
      }
    }
  ]
}